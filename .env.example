# Capstone Project Configuration
# Pass these values in your Vercel Project Settings (Environment Variables)

# 📞 The phone number displayed to students for coordination (e.g. 9876543210)
VITE_CAPSTONE_SHOP_MOBILE=9762626246

# 💰 Extra service fee for project handling (e.g. 50)
VITE_CAPSTONE_PROJECT_SERVICE_FEE=0

# 🎓 List of allowed colleges (Optional, comma-separated)
VITE_CAPSTONE_COLLEGE_LIST=

# ⚙️ Feature flag to enable/disable the portal (true/false)
VITE_CAPSTONE_FEATURE_ENABLED=true
